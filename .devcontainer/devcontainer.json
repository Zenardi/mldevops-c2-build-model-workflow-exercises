{
  "name": "MLDevOps Exercises",

  // Miniconda base gives us conda for `mlflow run .` which creates isolated conda envs per exercise
  "image": "mcr.microsoft.com/devcontainers/miniconda:latest",

  "features": {
    // Installs zsh + Oh My Zsh and sets it as the default shell
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefault": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        // Theme & icons
        "enkia.tokyo-night",
        "pkief.material-icon-theme",
        // Python & Jupyter
        "ms-python.python",
        "ms-python.debugpy",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow",
        // Config & docs
        "redhat.vscode-yaml",
        "yzhang.markdown-all-in-one",
        // Diagramming
        "hediet.vscode-drawio",
        // GitHub Copilot
        "github.copilot-chat"
      ],
      "settings": {
        "workbench.colorTheme": "Tokyo Night",
        "workbench.iconTheme": "material-icon-theme",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        }
      }
    }
  },

  // Make WANDB_API_KEY available inside the container.
  // In Codespaces it comes from the repository secret; locally it falls back to the host env var.
  "remoteEnv": {
    "WANDB_API_KEY": "${localEnv:WANDB_API_KEY}"
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  // Forward Jupyter and MLflow tracking server ports
  "forwardPorts": [8888, 5000],
  "portsAttributes": {
    "8888": { "label": "Jupyter" },
    "5000": { "label": "MLflow UI" }
  },

  "remoteUser": "vscode"
}
